BUILDROOT_HOME=/home/vboxuser/buildroot
CC=$(BUILDROOT_HOME)/output/host/usr/bin/arm-linux-gcc
CFLAGS=--sysroot=$(BUILDROOT_HOME)/output/staging -Wall
LIBS=-lcurl -lc

MAIN=thermostat_client
SRC=thermostat_client.c
OBJ=$(SRC:.c=.o)

all: $(MAIN)

$(MAIN): $(OBJ)
	$(CC) $(CFLAGS) -o $(MAIN) $(OBJ) $(LIBS)

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f $(MAIN) *.o
